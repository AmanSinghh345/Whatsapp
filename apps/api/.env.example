PORT=4000
CORS_ORIGIN=http://localhost:3000
# For deployed apps, prefer a comma-separated list:
# CORS_ORIGINS=http://localhost:3000,https://your-web-app.vercel.app
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chat_app?schema=public
# Optional for local development. Set this in production to your managed Redis URL.
REDIS_URL=redis://localhost:6379

CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Firebase Admin SDK credentials (from Firebase service account)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
